{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Infernet",
  "version": "0.1.0",
  "identifier": "dev.infernet.ui",
  "build": {
    "beforeDevCommand": "npm run prepare-runtime && npm run dev",
    "beforeBuildCommand": "npm run prepare-runtime && npm run build",
    "devUrl": "http://127.0.0.1:43127",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Infernet",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/llama-cli",
      "binaries/infernet-llama-bridge",
      "binaries/ggml-rpc-server",
      "binaries/llama-server",
      "binaries/sd-cli",
      "binaries/infernet-image-rpc-server"
    ],
    "macOS": {
      "hardenedRuntime": true,
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWcgcHVibGljIGtleTogN0M3Q0MxQjRBRDI5NjlDMgpSV1RDYVNtdHRNRjhmRDZrR1UxdWRJRVN1ZkxYNy9ZaCszOVozc1g2aHgvNjM2eFRNVnh0M1ZXNAo=",
      "endpoints": [
        "https://github.com/GnosysLabs/Infernet/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
